{
  "name": "n8n-nodes-scriptureflow",
  "version": "0.1.3",
  "description": "Use ScriptureFlow in n8n workflows to discover translations and retrieve attributed Scripture from the public API.",
  "license": "MIT",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "scriptureflow",
    "bible",
    "scripture",
    "automation"
  ],
  "author": {
    "name": "Johnathan Lightfoot",
    "email": "johnathan@bulletproofautomations.com",
    "url": "https://github.com/Exnav29/n8n-nodes-scriptureflow"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Exnav29/n8n-nodes-scriptureflow.git"
  },
  "homepage": "https://github.com/Exnav29/n8n-nodes-scriptureflow#readme",
  "bugs": {
    "url": "https://github.com/Exnav29/n8n-nodes-scriptureflow/issues"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist",
    "docs/scriptureflow-node-roadmap.md",
    "docs/publishing-readiness.md"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [],
    "nodes": [
      "dist/nodes/ScriptureFlow/Scriptureflow.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "0.35.1",
    "eslint": "9.29.0",
    "prettier": "3.6.2",
    "release-it": "^19.0.4",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
